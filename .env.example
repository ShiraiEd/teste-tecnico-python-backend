# Copie este arquivo para .env e ajuste os valores conforme necessário.
# O .env nunca deve ser commitado (já está no .gitignore).

# Caminho do arquivo SQLite. Em testes, sobrescrito por ":memory:".
DB_PATH=performance.db

# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Origens permitidas pelo CORS (separadas por vírgula, sem espaços)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate limit do POST /registro-foco (requisições por minuto por IP)
RATE_LIMIT=30
